---
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/gallery.css";
import "../../styles/fonts-gallery.css";
import "../../styles/legal.css";

const lastUpdated = "July 24, 2026";
const contactEmail = "silverrabbit.legal@gmail.com";
const owner = "Silver";
const siteUrl = "https://silver-rabbit.vercel.app";
---

<BaseLayout>
  <title slot="head">Terms of Service</title>

  <main class="legal">
    <h1>Terms of Service</h1>
    <p class="meta">Last updated: {lastUpdated}</p>

    <p>
      These Terms of Service (“Terms”) govern your use of this website
      ({siteUrl}) (the “Service”), operated by {owner}. By accessing or using the
      Service, you agree to be bound by these Terms. If you do not agree, please
      do not use the Service.
    </p>

    <h2>1. The Service</h2>
    <p>
      The Service provides access to stories and allows signed-in users to rate
      them. The Service is provided for personal, non-commercial use.
    </p>

    <h2>2. Accounts</h2>
    <p>
      You can sign in using Google. You are responsible for maintaining the
      security of your Google account and for any activity that occurs under your
      account. You must provide accurate information and must not impersonate
      others or use the Service in violation of any law.
    </p>

    <h2>3. Acceptable use</h2>
    <p>You agree not to:</p>
    <ul>
      <li>Attempt to disrupt, overload, or gain unauthorized access to the Service.</li>
      <li>Use automated means to scrape or copy content except as expressly permitted.</li>
      <li>Use the Service for any unlawful, harmful, or abusive purpose.</li>
    </ul>

    <h2>4. User content</h2>
    <p>
      Ratings and similar interactions you submit are stored and associated with
      your account. You are responsible for your submissions and grant us the
      right to store and process them to operate the Service.
    </p>

    <h2>5. Intellectual property</h2>
    <p>
      Content made available through the Service is protected by applicable
      intellectual property laws. You may not reproduce, distribute, or create
      derivative works from it without permission, except as allowed by law.
    </p>

    <h2>6. Disclaimer</h2>
    <p>
      The Service is provided “as is” and “as available”, without warranties of
      any kind, whether express or implied, including fitness for a particular
      purpose and non-infringement. We do not warrant that the Service will be
      uninterrupted, error-free, or secure.
    </p>

    <h2>7. Limitation of liability</h2>
    <p>
      To the maximum extent permitted by law, {owner} shall not be liable for any
      indirect, incidental, special, consequential, or punitive damages, or any
      loss of data or profits, arising from your use of or inability to use the
      Service.
    </p>

    <h2>8. Termination</h2>
    <p>
      We may suspend or terminate your access to the Service at any time if you
      violate these Terms or if we discontinue the Service. You may stop using
      the Service and request deletion of your account at any time.
    </p>

    <h2>9. Changes to these Terms</h2>
    <p>
      We may update these Terms from time to time. Continued use of the Service
      after changes take effect constitutes acceptance of the updated Terms.
    </p>

    <h2>10. Contact</h2>
    <p>
      Questions about these Terms can be sent to <a href={`mailto:${contactEmail}`}>{contactEmail}</a>.
    </p>

    <p class="back"><a href="/">← Back to home</a></p>
  </main>

  <style>
    .legal {
      max-width: 720px;
      margin: 0 auto;
      padding: 3rem 1.25rem 4rem;
      line-height: 1.65;
      font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
      color: #1a1a1a;
    }
    .legal h1 {
      font-size: 2rem;
      margin: 0 0 0.25rem;
    }
    .legal h2 {
      font-size: 1.2rem;
      margin: 2rem 0 0.5rem;
    }
    .legal .meta {
      color: #666;
      margin: 0 0 2rem;
      font-size: 0.9rem;
    }
    .legal ul {
      padding-left: 1.25rem;
    }
    .legal li {
      margin: 0.35rem 0;
    }
    .legal a {
      color: #2563eb;
    }
    .legal .back {
      margin-top: 2.5rem;
    }
    @media (prefers-color-scheme: dark) {
      .legal {
        color: #e6e6e6;
      }
      .legal .meta {
        color: #9a9a9a;
      }
      .legal a {
        color: #7ab0ff;
      }
    }
  </style>
</BaseLayout>
