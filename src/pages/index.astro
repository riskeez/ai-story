---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import StoryCard from "../components/StoryCard.astro";
import AccountButton from "../components/AccountButton.astro";
import { collection, storyAsset, url } from "../lib/site";
import { pluralRu } from "../lib/plural";
import { fetchAllStats } from "../lib/ratings";
import "../styles/gallery.css";
import "../styles/fonts-gallery.css";

const entries =(await getCollection("stories")).sort(
  (a, b) => b.data.date.iso.localeCompare(a.data.date.iso)
);

// Ratings baked in at build time; refreshed in the background on the client.
const ratingStats = new Map(
  (await fetchAllStats().catch(() => [])).map((r) => [r.story_slug, r])
);

const n = entries.length;
const countLabel = `${n} ${pluralRu(n, "история", "истории", "историй")}`;

// набор тегов для фильтра
const tags = ["Все", ...new Set(entries.flatMap((e) => e.data.tags))];

// preload LCP-обложки первой карточки
const first = entries[0];
const lcp = first
  ? storyAsset(first.id, first.data.thumb || first.data.hero)
  : null;
---
<BaseLayout>
  <Fragment slot="head">
    <title>{collection.title}</title>
    <meta name="description" content="Антология AI рассказов." />
    {lcp && <link rel="preload" as="image" href={lcp} fetchpriority="high" />}
    <link rel="preload" as="font" type="font/woff2" href="/fonts/spectral-600-cyrillic.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/pt-sans-400-cyrillic.woff2" crossorigin />
  </Fragment>

  <div class="page">
    <div class="bg" aria-hidden="true"></div>
    <div class="topline" aria-hidden="true"></div>

    <header class="masthead">
      <div class="index-row">
        <span class="k">
          <img class="mast-logo" src={url("logo.webp")} alt="" width="28" height="28" decoding="async" />
          {collection.kicker}
        </span>
        <span class="index-right">
          <span class="count">{countLabel}</span>
          <AccountButton />
        </span>
      </div>
      <h1 class="mast-title">{collection.title}</h1>
      {collection.tagline && <p class="tagline">{collection.tagline}</p>}
    </header>

    <nav class="filters" id="filters" aria-label="Фильтр по тегам">
      <div class="filters-inner wrap">
        <span class="lbl">Тема</span>
        {
          tags.map((t) => (
            <button
              class="chip"
              data-on={t === "Все" ? "1" : "0"}
              data-tag={t}
            >
              {t}
            </button>
          ))
        }
      </div>
    </nav>

    <main class="grid wrap" id="grid">
      {entries.map((entry, i) => <StoryCard entry={entry} index={i} stat={ratingStats.get(entry.id)} />)}
    </main>
  </div>

  <script src="../scripts/gallery.ts"></script>
  <script>
    // Badges are rendered at build time; refresh them with the latest votes.
    const badges = document.querySelectorAll<HTMLElement>(".card-rating[data-slug]");
    if (badges.length) {
      const { fetchAllStats } = await import("../lib/ratings");
      const stats = new Map((await fetchAllStats()).map((r) => [r.story_slug, r]));
      badges.forEach((el) => {
        const r = stats.get(el.dataset.slug!);
        const show = !!r && r.votes > 0;
        if (show) el.innerHTML = `<span class="rt-star">★</span> ${r!.avg_score.toFixed(1)} · ${r!.votes}`;
        el.hidden = !show;
      });
    }
  </script>
</BaseLayout>
